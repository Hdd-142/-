/* 第6页 - 肩颈舒缓视频页样式 */

.page-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #FFF8DC;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.video-cover {
  width: 600rpx;
  height: 340rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f5e6d3 0%, #e8d5c4 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
}

.play-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(93, 78, 55, 0.8);
  color: #fff;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.play-text {
  font-size: 28rpx;
  color: #8B7355;
}

.video-label {
  font-size: 28rpx;
  color: #8B7355;
  text-align: center;
  margin-top: 30rpx;
}

.touch-hint {
  position: fixed;
  bottom: 60rpx;
  font-size: 24rpx;
  color: #A0937D;
}
